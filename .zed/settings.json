{
	"theme": "Ayu Dark",
	"preferred_line_length": 120,
	"show_whitespaces": "none",
	"remove_trailing_whitespace_on_save": false,
	"soft_wrap": "editor_width",
	"ui_font_family": "IBM Plex Mono",
	"buffer_font_size": 13,
	"buffer_font_family": "IBM Plex Mono",
	"hard_tabs": true,
	"tab_size": 3,
	"formatter": "auto",
	"format_on_save": "on",
	"code_actions_on_format": {
		"source.fixAll": true,
		"source.organizeImports": true
	},
	"git": {
		"inline_blame": {
			"enabled": true,
			"min_column": 60,
			"show_commit_summary": true
		}
	},
	"auto_install_extensions": {
		"biome": true,
		"dockerfile": true,
		"html": true,
		"nix": true,
		"terraform": true,
		"toml": true,
		"vue": true
	},
	"agent": {
		"dock": "left",
		"model_parameters": [],
		"default_model": {
			"provider": "openrouter",
			"model": "google/gemini-2.5-pro"
		}
	},
	"base_keymap": "VSCode",
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"vim_mode": false,
	"ui_font_size": 13
}
